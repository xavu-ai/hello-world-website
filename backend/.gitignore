# ============================================================
# Standard .gitignore for OpenClaw AI team project repos
# Copy this to the root of every project repo as .gitignore
# ============================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# Python tools
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---- Node.js / Frontend ----
node_modules/
.next/
out/
.nuxt/
.cache/
.turbo/
.vercel/
.output/
*.tsbuildinfo

# Package manager
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# ---- Docker ----
# Don't ignore Dockerfiles or docker-compose, but ignore runtime
docker-compose.override.yml

# ---- IDE / Editor ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
!.env.example
!.env.template

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ---- Misc build artifacts ----
*.log
logs/
tmp/
temp/
.cache/
coverage/
