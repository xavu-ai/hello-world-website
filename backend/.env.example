# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration (comma-separated allowed origins, or * for any)
# Note: no wildcard in production
CORS_ORIGINS=https://example.com

# Rate Limiting (15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Static Files
STATIC_DIR=./public

# Logging
LOG_LEVEL=combined
